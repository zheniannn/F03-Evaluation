__pycache__/
*.pyc
.venv/
.env

# Large generated CSVs are never committed -- only directory structure.
data/active/radar_truth_relocated/*.csv
data/active/sim_detections_relocated/*.csv
data/active/tracks_kalman/*.csv

!data/active/radar_truth_relocated/.gitkeep
!data/active/sim_detections_relocated/.gitkeep
!data/active/tracks_kalman/.gitkeep
data/active/tracks_scored_physics/*.csv
!data/active/tracks_scored_physics/.gitkeep
data/active/trajectories_10s/*.csv
!data/active/trajectories_10s/.gitkeep
models/sequence_priors/*.pt
!models/sequence_priors/.gitkeep
reports/stage12_sequence_priors/sequence_track_scores.csv
models/vae_priors/*.pt
!models/vae_priors/.gitkeep
reports/stage13_vae_prior/vae_track_scores.csv
models/diffusion_denoisers/*.pt
!models/diffusion_denoisers/.gitkeep
reports/stage15_diffusion_denoising/diffusion_residual_scores.csv

# stage 17: large per-track score CSVs generated per day (never commit)
reports/stage17_four_day_validation/generated/**/sequence_track_scores.csv
reports/stage17_four_day_validation/generated/**/physics_track_scores.csv
reports/stage17_four_day_validation/generated/**/*_track_scores.csv

# stage 09/11 per-track score CSVs (large, regenerable; siblings already ignored)
reports/stage09_physics_scoring/physics_track_scores.csv
reports/stage11_adsb_prior_scoring/adsb_prior_track_scores.csv

# stage 22: F04 cube-derived detections imported into F03 (large, regenerable)
data/active/f04_cube_detections/*.csv
data/active/f04_cube_detections/*.json
data/active/tracks_kalman_f04_cube/*.csv
reports/stage22_f04_cube_eval/generated/*.csv
reports/stage22_f04_cube_eval/generated/scored_tracks_f04_cube/
# per-track score CSVs are large and regenerable, as everywhere else in this repo
reports/stage22_f04_cube_eval/**/*_track_scores.csv

!data/active/f04_cube_detections/.gitkeep
!data/active/tracks_kalman_f04_cube/.gitkeep
